meta {
  name: Get Health
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/healthz
  body: none
  auth: none
}

tests {
  test("responds with status 200", function() {
    expect(res.status).to.equal(200);
  });

  test("body status is ok", function() {
    expect(res.body.status).to.equal("ok");
  });
}
