meta {
  name: Get Status Page JSON Summary
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/summary/{{summaryUuid}}
  body: none
  auth: none
}

tests {
  test("responds with status 200 or 404", function() {
    expect(res.status).to.be.oneOf([200, 404]);
  });

  test("content-type is application/json", function() {
    expect(res.headers["content-type"]).to.include("application/json");
  });

  test("if 200: body has required fields", function() {
    if (res.status === 200) {
      expect(res.body).to.have.property("name");
      expect(res.body).to.have.property("slug");
      expect(res.body).to.have.property("all_operational");
      expect(res.body).to.have.property("monitors");
      expect(res.body).to.have.property("generated_at");
      expect(res.body.monitors).to.be.an("array");
    }
  });

  test("if 200: each monitor has required fields", function() {
    if (res.status === 200) {
      res.body.monitors.forEach(function(m) {
        expect(m).to.have.property("id");
        expect(m).to.have.property("name");
        expect(m).to.have.property("status");
        expect(m).to.have.property("uptime_24h");
      });
    }
  });

  test("if 404: body has error field", function() {
    if (res.status === 404) {
      expect(res.body).to.have.property("error");
    }
  });
}
