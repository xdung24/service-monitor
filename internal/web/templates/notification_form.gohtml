                <input class="form-control" type="password" name="cfg_pass"
                       value="{{ index .Config "pass" }}" autocomplete="new-password" />
                <small class="hint">Enable SMS notifications in your Free Mobile account to obtain the key.</small>
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Octopush -->
        <!-- ======================================================= -->
        <div id="fields-octopush" class="provider-fields">
