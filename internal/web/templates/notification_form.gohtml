        </div>

        <!-- ======================================================= -->
        <!-- PromoSMS -->
        <!-- ======================================================= -->
        <div id="fields-promosms" class="provider-fields">
            <div class="two-col">
                <div class="form-group">
                    <label>Login</label>
                    <input class="form-control" type="text" name="cfg_login"
                           value="{{ index .Config "login" }}" />
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input class="form-control" type="password" name="cfg_password"
                           value="{{ index .Config "password" }}" autocomplete="new-password" />
                </div>
            </div>
            <div class="two-col">
                <div class="form-group">
                    <label>From</label>
                    <input class="form-control" type="text" name="cfg_from"
                           value="{{ index .Config "from" }}" placeholder="+15551234567 or MyBrand" />
                </div>
                <div class="form-group">
                    <label>To</label>
                    <input class="form-control" type="tel" name="cfg_to"
                           value="{{ index .Config "to" }}" placeholder="+48600100200" />
                </div>
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- SMSC.ru -->
        <!-- ======================================================= -->
        <div id="fields-smsc" class="provider-fields">
            <div class="two-col">
                <div class="form-group">
                    <label>Login</label>
                    <input class="form-control" type="text" name="cfg_login"
                           value="{{ index .Config "login" }}" />
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input class="form-control" type="password" name="cfg_password"
                           value="{{ index .Config "password" }}" autocomplete="new-password" />
                </div>
            </div>
            <div class="form-group">
                <label>Phone Numbers <span class="text-muted">(comma-separated)</span></label>
                <input class="form-control" type="text" name="cfg_phones"
                       value="{{ index .Config "phones" }}" placeholder="+79161234567,+79167654321" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- SMSEagle -->
        <!-- ======================================================= -->
        <div id="fields-smseagle" class="provider-fields">
            <div class="form-group">
                <label>SMSEagle Device URL</label>
                <input class="form-control" type="url" name="cfg_url"
                       value="{{ index .Config "url" }}" placeholder="http://192.168.1.100" />
            </div>
            <div class="two-col">
                <div class="form-group">
                    <label>Login</label>
                    <input class="form-control" type="text" name="cfg_login"
                           value="{{ index .Config "login" }}" />
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input class="form-control" type="password" name="cfg_password"
                           value="{{ index .Config "password" }}" autocomplete="new-password" />
                </div>
            </div>
            <div class="form-group">
                <label>Recipient Phone</label>
                <input class="form-control" type="tel" name="cfg_to"
                       value="{{ index .Config "to" }}" placeholder="+15559876543" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- SMS.ir -->
        <!-- ======================================================= -->
        <div id="fields-smsir" class="provider-fields">
            <div class="form-group">
                <label>API Key</label>
                <input class="form-control" type="password" name="cfg_api_key"
                       value="{{ index .Config "api_key" }}" autocomplete="new-password" />
                <small class="hint">Get your API key at app.sms.ir.</small>
            </div>
            <div class="two-col">
                <div class="form-group">
                    <label>Line Number</label>
                    <input class="form-control" type="text" name="cfg_line_number"
                           value="{{ index .Config "line_number" }}" placeholder="30004820" />
                </div>
                <div class="form-group">
                    <label>Mobile (recipient)</label>
                    <input class="form-control" type="tel" name="cfg_mobile"
                           value="{{ index .Config "mobile" }}" placeholder="+989121234567" />
                </div>
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Teltonika -->
        <!-- ======================================================= -->
        <div id="fields-teltonika" class="provider-fields">
            <div class="form-group">
                <label>Router URL</label>
                <input class="form-control" type="url" name="cfg_url"
                       value="{{ index .Config "url" }}" placeholder="http://192.168.1.1" />
            </div>
            <div class="two-col">
                <div class="form-group">
                    <label>Username</label>
                    <input class="form-control" type="text" name="cfg_username"
                           value="{{ index .Config "username" }}" placeholder="admin" />
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input class="form-control" type="password" name="cfg_password"
                           value="{{ index .Config "password" }}" autocomplete="new-password" />
                </div>
            </div>
            <div class="form-group">
                <label>Recipient Phone</label>
                <input class="form-control" type="tel" name="cfg_phone"
                       value="{{ index .Config "phone" }}" placeholder="+15559876543" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Active + Submit -->
        <!-- ======================================================= -->
        <div class="form-group" style="margin-top:1.25rem; padding-top:1rem; border-top:1px solid #334155;">
            <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
                <input type="checkbox" name="active" value="on"
                       {{ if .Notification.Active }}checked{{ end }} />
                Active
            </label>
        </div>

        <div style="display:flex; gap:0.75rem; margin-top:1rem;">
            <button type="submit" class="btn btn-primary">
                {{ if .IsNew }}Create Provider{{ else }}Save Changes{{ end }}
            </button>
            <a href="/notifications" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>

    </div>
    <script>
        // Providers that map to the shared "url-plain" section.
        const URL_PLAIN = new Set([
            'slack','discord','mattermost','rocketchat',
            'dingding','feishu','googlechat','teams','wecom','yzj','lunasea'
        ]);
        // Providers that share the "sms-creds" section (username/password/from/to).
        const SMS_CREDS = new Set(['46elks','cellsynt','gtxmessaging','serwersms']);
        // Providers that share the "email-api" section (api_key/from/to).
        const EMAIL_API = new Set(['sendgrid','resend','sevenio']);

        function sectionFor(type) {
            if (URL_PLAIN.has(type)) return 'url-plain';
            if (SMS_CREDS.has(type)) return 'sms-creds';
            if (EMAIL_API.has(type)) return 'email-api';
            return type;
        }

        function showFields(type) {
            // Disable every cfg input in every provider section so the browser
            // does not submit values from inactive sections.
            document.querySelectorAll(
                '.provider-fields input, .provider-fields select, .provider-fields textarea'
            ).forEach(el => { el.disabled = true; });
            document.querySelectorAll('.provider-fields')
                    .forEach(el => el.classList.remove('active'));

            if (!type) return;
            const section = document.getElementById('fields-' + sectionFor(type));
            if (section) {
                section.classList.add('active');
                section.querySelectorAll('input, select, textarea')
                       .forEach(el => { el.disabled = false; });
            }
        }

        // Activate the correct section on initial page load.
        showFields(document.getElementById('type').value);
    </script>
</body>
</html>
{{ end }}
