            <div class="two-col">
                <div class="form-group">
                    <label>Sender Name</label>
                    <input class="form-control" type="text" name="cfg_sender_name"
                           value="{{ index .Config "sender_name" }}" placeholder="ServiceMon" />
                </div>
                <div class="form-group">
                    <label>Sender Phone</label>
                    <input class="form-control" type="tel" name="cfg_sender_sms"
                           value="{{ index .Config "sender_sms" }}" placeholder="+15551234567" />
                </div>
