                    <option value="whatsapp" {{ if ne (index .Config "type") "signal" }}selected{{ end }}>WhatsApp</option>
                    <option value="signal"   {{ if eq (index .Config "type") "signal" }}selected{{ end }}>Signal</option>
                </select>
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Free Mobile -->
        <!-- ======================================================= -->
        <div id="fields-freemobile" class="provider-fields">
