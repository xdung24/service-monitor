                       value="{{ index .Config "recipients" }}" placeholder="+33612345678,+33612345679" />
            </div>
            <div class="form-group">
                <label>Sender Name</label>
                <input class="form-control" type="text" name="cfg_sender"
                       value="{{ index .Config "sender" }}" placeholder="ServiceMon" />
