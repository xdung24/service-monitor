{{ define "notification_form.gohtml" }}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ if .IsNew }}New Notification{{ else }}Edit Notification{{ end }} — Conductor</title>
    {{ template "styles" . }}
    <style>
        .provider-fields { display: none; }
        .provider-fields.active { display: block; }
        .hint { color: #64748b; font-size: 0.775rem; display: block; margin-top: 0.25rem; }
        .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        @media (max-width: 520px) { .two-col { grid-template-columns: 1fr; } }
    </style>
</head>
<body>
    {{ template "navbar" . }}
    <div class="container">

<h1 class="page-title">{{ if .IsNew }}Add Notification Provider{{ else }}Edit Notification Provider{{ end }}</h1>

{{ if .Error }}
<div class="alert alert-danger">{{ .Error }}</div>
{{ end }}

<div class="card" style="max-width:680px;">
    <form method="POST" action="{{ if .IsNew }}/notifications{{ else }}/notifications/{{ .Notification.ID }}{{ end }}">

        <div class="form-group">
            <label for="name">Display Name</label>
            <input class="form-control" type="text" id="name" name="name"
                   value="{{ .Notification.Name }}" placeholder="My Alert Channel" required />
        </div>

        <div class="form-group">
            <label for="type">Provider Type</label>
            <select class="form-control" id="type" name="type" onchange="showFields(this.value)">
                <option value="">— select type —</option>
                <optgroup label="Webhooks &amp; Messaging">
                    <option value="webhook"    {{ if eq .Notification.Type "webhook"    }}selected{{ end }}>Webhook (custom HTTP)</option>
                    <option value="slack"      {{ if eq .Notification.Type "slack"      }}selected{{ end }}>Slack</option>
                    <option value="discord"    {{ if eq .Notification.Type "discord"    }}selected{{ end }}>Discord</option>
                    <option value="mattermost" {{ if eq .Notification.Type "mattermost" }}selected{{ end }}>Mattermost</option>
                    <option value="rocketchat" {{ if eq .Notification.Type "rocketchat" }}selected{{ end }}>Rocket.Chat</option>
                    <option value="dingding"   {{ if eq .Notification.Type "dingding"   }}selected{{ end }}>DingTalk</option>
                    <option value="feishu"     {{ if eq .Notification.Type "feishu"     }}selected{{ end }}>Feishu / Lark</option>
                    <option value="googlechat" {{ if eq .Notification.Type "googlechat" }}selected{{ end }}>Google Chat</option>
                    <option value="teams"      {{ if eq .Notification.Type "teams"      }}selected{{ end }}>Microsoft Teams</option>
                    <option value="wecom"      {{ if eq .Notification.Type "wecom"      }}selected{{ end }}>WeCom</option>
                    <option value="yzj"        {{ if eq .Notification.Type "yzj"        }}selected{{ end }}>YZJ (云之家)</option>
                    <option value="lunasea"    {{ if eq .Notification.Type "lunasea"    }}selected{{ end }}>LunaSea</option>
                </optgroup>
                <optgroup label="Push Notifications">
                    <option value="telegram"      {{ if eq .Notification.Type "telegram"      }}selected{{ end }}>Telegram</option>
                    <option value="ntfy"          {{ if eq .Notification.Type "ntfy"          }}selected{{ end }}>ntfy</option>
                    <option value="gotify"        {{ if eq .Notification.Type "gotify"        }}selected{{ end }}>Gotify</option>
                    <option value="bark"          {{ if eq .Notification.Type "bark"          }}selected{{ end }}>Bark (iOS)</option>
                    <option value="gorush"        {{ if eq .Notification.Type "gorush"        }}selected{{ end }}>Gorush</option>
                    <option value="pushover"      {{ if eq .Notification.Type "pushover"      }}selected{{ end }}>Pushover</option>
                    <option value="pushplus"      {{ if eq .Notification.Type "pushplus"      }}selected{{ end }}>PushPlus</option>
                    <option value="serverchan"    {{ if eq .Notification.Type "serverchan"    }}selected{{ end }}>ServerChan (Server酱)</option>
                    <option value="line"          {{ if eq .Notification.Type "line"          }}selected{{ end }}>LINE Notify</option>
                    <option value="homeassistant" {{ if eq .Notification.Type "homeassistant" }}selected{{ end }}>Home Assistant</option>
                </optgroup>
                <optgroup label="Incident Management">
                    <option value="pagerduty" {{ if eq .Notification.Type "pagerduty" }}selected{{ end }}>PagerDuty</option>
                </optgroup>
                <optgroup label="Messaging Apps">
                    <option value="matrix"    {{ if eq .Notification.Type "matrix"    }}selected{{ end }}>Matrix / Element</option>
                    <option value="signal"    {{ if eq .Notification.Type "signal"    }}selected{{ end }}>Signal</option>
                    <option value="waha"      {{ if eq .Notification.Type "waha"      }}selected{{ end }}>WAHA (WhatsApp HTTP API)</option>
                    <option value="whapi"     {{ if eq .Notification.Type "whapi"     }}selected{{ end }}>Whapi (WhatsApp)</option>
                    <option value="onesender" {{ if eq .Notification.Type "onesender" }}selected{{ end }}>OneSender</option>
                    <option value="onebot"    {{ if eq .Notification.Type "onebot"    }}selected{{ end }}>OneBot (QQ)</option>
                    <option value="evolution" {{ if eq .Notification.Type "evolution" }}selected{{ end }}>Evolution API (WhatsApp)</option>
                </optgroup>
                <optgroup label="Email">
                    <option value="email"    {{ if eq .Notification.Type "email"    }}selected{{ end }}>Email (SMTP)</option>
                    <option value="sendgrid" {{ if eq .Notification.Type "sendgrid" }}selected{{ end }}>SendGrid</option>
                    <option value="resend"   {{ if eq .Notification.Type "resend"   }}selected{{ end }}>Resend</option>
                    <option value="twilio"   {{ if eq .Notification.Type "twilio"   }}selected{{ end }}>Twilio (SMS)</option>
                </optgroup>
                <optgroup label="SMS">
                    <option value="46elks"       {{ if eq .Notification.Type "46elks"       }}selected{{ end }}>46elks</option>
                    <option value="brevo"        {{ if eq .Notification.Type "brevo"        }}selected{{ end }}>Brevo SMS</option>
                    <option value="callmebot"    {{ if eq .Notification.Type "callmebot"    }}selected{{ end }}>CallMeBot</option>
                    <option value="cellsynt"     {{ if eq .Notification.Type "cellsynt"     }}selected{{ end }}>Cellsynt</option>
                    <option value="freemobile"   {{ if eq .Notification.Type "freemobile"   }}selected{{ end }}>Free Mobile</option>
                    <option value="gtxmessaging" {{ if eq .Notification.Type "gtxmessaging" }}selected{{ end }}>GTX Messaging</option>
                    <option value="octopush"     {{ if eq .Notification.Type "octopush"     }}selected{{ end }}>Octopush</option>
                    <option value="promosms"     {{ if eq .Notification.Type "promosms"     }}selected{{ end }}>PromoSMS</option>
                    <option value="serwersms"    {{ if eq .Notification.Type "serwersms"    }}selected{{ end }}>SerwerSMS</option>
                    <option value="sevenio"      {{ if eq .Notification.Type "sevenio"      }}selected{{ end }}>seven.io</option>
                    <option value="smsc"         {{ if eq .Notification.Type "smsc"         }}selected{{ end }}>SMSC.ru</option>
                    <option value="smseagle"     {{ if eq .Notification.Type "smseagle"     }}selected{{ end }}>SMSEagle</option>
                    <option value="smsir"        {{ if eq .Notification.Type "smsir"        }}selected{{ end }}>SMS.ir</option>
                    <option value="teltonika"    {{ if eq .Notification.Type "teltonika"    }}selected{{ end }}>Teltonika</option>
                </optgroup>
            </select>
        </div>

        <!-- ======================================================= -->
        <!-- Webhook -->
        <!-- ======================================================= -->
        <div id="fields-webhook" class="provider-fields">
            <div class="form-group">
                <label>Webhook URL</label>
                <input class="form-control" type="url" name="cfg_url"
                       value="{{ index .Config "url" }}" placeholder="https://hooks.example.com/..." />
            </div>
            <div class="form-group">
                <label>Secret <span class="text-muted">(optional — sent as X-Webhook-Secret header)</span></label>
                <input class="form-control" type="text" name="cfg_secret"
                       value="{{ index .Config "secret" }}" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- URL-only (Slack, Discord, Mattermost, Rocket.Chat,      -->
        <!-- DingTalk, Feishu, Google Chat, Teams, WeCom, YZJ,       -->
        <!-- LunaSea)                                                 -->
        <!-- ======================================================= -->
        <div id="fields-url-plain" class="provider-fields">
            <div class="form-group">
                <label>Incoming Webhook URL</label>
                <input class="form-control" type="url" name="cfg_url"
                       value="{{ index .Config "url" }}" placeholder="https://..." />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Telegram -->
        <!-- ======================================================= -->
        <div id="fields-telegram" class="provider-fields">
            <div class="form-group">
                <label>Bot Token</label>
                <input class="form-control" type="text" name="cfg_bot_token"
                       value="{{ index .Config "bot_token" }}" placeholder="123456789:AABBcc..." />
                <small class="hint">Create a bot via @BotFather on Telegram, then copy the token it provides.</small>
            </div>
            <div class="form-group">
                <label>Chat ID</label>
                <input class="form-control" type="text" name="cfg_chat_id"
                       value="{{ index .Config "chat_id" }}" placeholder="-1001234567890" />
                <small class="hint">Negative for groups/channels, positive for direct messages. Call /getUpdates on your bot to find it.</small>
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- ntfy -->
        <!-- ======================================================= -->
        <div id="fields-ntfy" class="provider-fields">
            <div class="form-group">
                <label>Topic</label>
                <input class="form-control" type="text" name="cfg_topic"
                       value="{{ index .Config "topic" }}" placeholder="my-alerts" />
            </div>
            <div class="form-group">
                <label>Server URL <span class="text-muted">(optional, default: ntfy.sh)</span></label>
                <input class="form-control" type="url" name="cfg_server"
                       value="{{ index .Config "server" }}" placeholder="https://ntfy.sh" />
            </div>
            <div class="form-group">
                <label>Access Token <span class="text-muted">(optional)</span></label>
                <input class="form-control" type="password" name="cfg_token"
                       value="{{ index .Config "token" }}" autocomplete="new-password" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Gotify -->
        <!-- ======================================================= -->
        <div id="fields-gotify" class="provider-fields">
            <div class="form-group">
                <label>Server URL</label>
                <input class="form-control" type="url" name="cfg_url"
                       value="{{ index .Config "url" }}" placeholder="https://gotify.example.com" />
            </div>
            <div class="form-group">
                <label>App Token</label>
                <input class="form-control" type="password" name="cfg_token"
                       value="{{ index .Config "token" }}" autocomplete="new-password" />
            </div>
            <div class="form-group">
                <label>Priority <span class="text-muted">(optional, 0–10, default 5)</span></label>
                <input class="form-control" type="number" name="cfg_priority"
                       value="{{ index .Config "priority" }}" min="0" max="10" placeholder="5"
                       style="max-width:100px;" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Bark -->
        <!-- ======================================================= -->
        <div id="fields-bark" class="provider-fields">
            <div class="form-group">
                <label>Device Key</label>
                <input class="form-control" type="text" name="cfg_device_key"
                       value="{{ index .Config "device_key" }}" placeholder="AbCdEfGhIj..." />
                <small class="hint">Open the Bark app on iOS and copy the device key shown on the main screen.</small>
            </div>
            <div class="form-group">
                <label>Server URL <span class="text-muted">(optional, default: api.day.app)</span></label>
                <input class="form-control" type="url" name="cfg_server_url"
                       value="{{ index .Config "server_url" }}" placeholder="https://api.day.app" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Gorush -->
        <!-- ======================================================= -->
        <div id="fields-gorush" class="provider-fields">
            <div class="form-group">
                <label>Server URL</label>
                <input class="form-control" type="url" name="cfg_server_url"
                       value="{{ index .Config "server_url" }}" placeholder="https://gorush.example.com" />
            </div>
            <div class="form-group">
                <label>Device Tokens <span class="text-muted">(comma-separated)</span></label>
                <input class="form-control" type="text" name="cfg_tokens"
                       value="{{ index .Config "tokens" }}" placeholder="token1,token2" />
            </div>
            <div class="form-group">
                <label>Platform <span class="text-muted">(optional: 1 = iOS, 2 = Android)</span></label>
                <input class="form-control" type="text" name="cfg_platform"
                       value="{{ index .Config "platform" }}" placeholder="2" style="max-width:80px;" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Pushover -->
        <!-- ======================================================= -->
        <div id="fields-pushover" class="provider-fields">
            <div class="form-group">
                <label>User Key</label>
                <input class="form-control" type="text" name="cfg_user_key"
                       value="{{ index .Config "user_key" }}" placeholder="uQiRzpo4DXghDmr9..." />
                <small class="hint">Found on your dashboard at pushover.net after login.</small>
            </div>
            <div class="form-group">
                <label>API Token</label>
                <input class="form-control" type="password" name="cfg_api_token"
                       value="{{ index .Config "api_token" }}" autocomplete="new-password" />
                <small class="hint">Create an application at pushover.net/apps to obtain a token.</small>
            </div>
            <div class="form-group">
                <label>Device <span class="text-muted">(optional — blank sends to all devices)</span></label>
                <input class="form-control" type="text" name="cfg_device"
                       value="{{ index .Config "device" }}" placeholder="iphone" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- PushPlus -->
        <!-- ======================================================= -->
        <div id="fields-pushplus" class="provider-fields">
            <div class="form-group">
                <label>Token</label>
                <input class="form-control" type="password" name="cfg_token"
                       value="{{ index .Config "token" }}" autocomplete="new-password" />
                <small class="hint">Get your token at pushplus.plus.</small>
            </div>
            <div class="form-group">
                <label>Topic <span class="text-muted">(optional — for group push channel)</span></label>
                <input class="form-control" type="text" name="cfg_topic"
                       value="{{ index .Config "topic" }}" placeholder="leave blank for personal" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- ServerChan -->
        <!-- ======================================================= -->
        <div id="fields-serverchan" class="provider-fields">
            <div class="form-group">
                <label>SendKey</label>
                <input class="form-control" type="password" name="cfg_send_key"
                       value="{{ index .Config "send_key" }}" autocomplete="new-password" />
                <small class="hint">Obtain your send key at sct.ftqq.com.</small>
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- LINE Notify -->
        <!-- ======================================================= -->
        <div id="fields-line" class="provider-fields">
            <div class="form-group">
                <label>Access Token</label>
                <input class="form-control" type="password" name="cfg_token"
                       value="{{ index .Config "token" }}" autocomplete="new-password" />
                <small class="hint">Generate a token at notify-bot.line.me/my/.</small>
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Home Assistant -->
        <!-- ======================================================= -->
        <div id="fields-homeassistant" class="provider-fields">
            <div class="form-group">
                <label>Home Assistant URL</label>
                <input class="form-control" type="url" name="cfg_url"
                       value="{{ index .Config "url" }}" placeholder="http://homeassistant.local:8123" />
            </div>
            <div class="form-group">
                <label>Long-Lived Access Token</label>
                <input class="form-control" type="password" name="cfg_token"
                       value="{{ index .Config "token" }}" autocomplete="new-password" />
                <small class="hint">Create in HA → Profile → Long-lived access tokens.</small>
            </div>
            <div class="form-group">
                <label>Notification Service</label>
                <input class="form-control" type="text" name="cfg_notification_id"
                       value="{{ index .Config "notification_id" }}" placeholder="notify.mobile_app_myphone" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- PagerDuty -->
        <!-- ======================================================= -->
        <div id="fields-pagerduty" class="provider-fields">
            <div class="form-group">
                <label>Routing Key (Integration Key)</label>
                <input class="form-control" type="password" name="cfg_routing_key"
                       value="{{ index .Config "routing_key" }}" autocomplete="new-password"
                       placeholder="abcdef1234567890abcdef1234567890" />
                <small class="hint">From PagerDuty → Services → Integrations → Events API v2.</small>
            </div>
            <div class="form-group">
                <label>Severity <span class="text-muted">(optional)</span></label>
                <select class="form-control" name="cfg_severity" style="width:auto;">
                    <option value=""        {{ if eq (index .Config "severity") ""        }}selected{{ end }}>— auto (critical/info) —</option>
                    <option value="critical" {{ if eq (index .Config "severity") "critical" }}selected{{ end }}>critical</option>
                    <option value="error"    {{ if eq (index .Config "severity") "error"    }}selected{{ end }}>error</option>
                    <option value="warning"  {{ if eq (index .Config "severity") "warning"  }}selected{{ end }}>warning</option>
                    <option value="info"     {{ if eq (index .Config "severity") "info"     }}selected{{ end }}>info</option>
                </select>
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Matrix / Element -->
        <!-- ======================================================= -->
        <div id="fields-matrix" class="provider-fields">
            <div class="form-group">
                <label>Homeserver URL</label>
                <input class="form-control" type="url" name="cfg_homeserver_url"
                       value="{{ index .Config "homeserver_url" }}" placeholder="https://matrix.org" />
            </div>
            <div class="form-group">
                <label>Access Token</label>
                <input class="form-control" type="password" name="cfg_access_token"
                       value="{{ index .Config "access_token" }}" autocomplete="new-password" />
                <small class="hint">Log in with your Matrix client → Settings → copy the access token.</small>
            </div>
            <div class="form-group">
                <label>Room ID</label>
                <input class="form-control" type="text" name="cfg_room_id"
                       value="{{ index .Config "room_id" }}" placeholder="!roomId:matrix.org" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Signal (signal-cli-rest-api) -->
        <!-- ======================================================= -->
        <div id="fields-signal" class="provider-fields">
            <div class="form-group">
                <label>signal-cli-rest-api URL</label>
                <input class="form-control" type="url" name="cfg_url"
                       value="{{ index .Config "url" }}" placeholder="http://signal-api:8080" />
                <small class="hint">URL of your self-hosted signal-cli-rest-api instance.</small>
            </div>
            <div class="form-group">
                <label>Source Phone Number</label>
                <input class="form-control" type="tel" name="cfg_number"
                       value="{{ index .Config "number" }}" placeholder="+12025551234" />
            </div>
            <div class="form-group">
                <label>Recipients <span class="text-muted">(comma-separated phone numbers)</span></label>
                <input class="form-control" type="text" name="cfg_recipients"
                       value="{{ index .Config "recipients" }}" placeholder="+12025555678,+12025559012" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- WAHA (WhatsApp HTTP API) -->
        <!-- ======================================================= -->
        <div id="fields-waha" class="provider-fields">
            <div class="form-group">
                <label>WAHA Server URL</label>
                <input class="form-control" type="url" name="cfg_url"
                       value="{{ index .Config "url" }}" placeholder="http://waha:3000" />
            </div>
            <div class="form-group">
                <label>Recipient Phone or Group JID</label>
                <input class="form-control" type="text" name="cfg_phone"
                       value="{{ index .Config "phone" }}" placeholder="12025551234@s.whatsapp.net" />
            </div>
            <div class="form-group">
                <label>Session <span class="text-muted">(optional, default: default)</span></label>
                <input class="form-control" type="text" name="cfg_session"
                       value="{{ index .Config "session" }}" placeholder="default" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Whapi (WhatsApp) -->
        <!-- ======================================================= -->
        <div id="fields-whapi" class="provider-fields">
            <div class="form-group">
                <label>API Token</label>
                <input class="form-control" type="password" name="cfg_token"
                       value="{{ index .Config "token" }}" autocomplete="new-password" />
                <small class="hint">Get your channel token from app.whapi.cloud.</small>
            </div>
            <div class="form-group">
                <label>Recipient Phone Number</label>
                <input class="form-control" type="tel" name="cfg_phone"
                       value="{{ index .Config "phone" }}" placeholder="+12025551234" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- OneSender -->
        <!-- ======================================================= -->
        <div id="fields-onesender" class="provider-fields">
            <div class="form-group">
                <label>Server URL</label>
                <input class="form-control" type="url" name="cfg_url"
                       value="{{ index .Config "url" }}" placeholder="http://onesender:3000" />
            </div>
            <div class="form-group">
                <label>Token</label>
                <input class="form-control" type="password" name="cfg_token"
                       value="{{ index .Config "token" }}" autocomplete="new-password" />
            </div>
            <div class="form-group">
                <label>Recipient Phone Number</label>
                <input class="form-control" type="tel" name="cfg_phone"
                       value="{{ index .Config "phone" }}" placeholder="+12025551234" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- OneBot (QQ) -->
        <!-- ======================================================= -->
        <div id="fields-onebot" class="provider-fields">
            <div class="form-group">
                <label>OneBot HTTP URL</label>
                <input class="form-control" type="url" name="cfg_url"
                       value="{{ index .Config "url" }}" placeholder="http://onebot:5700" />
            </div>
            <div class="form-group">
                <label>Target (User or Group ID)</label>
                <input class="form-control" type="text" name="cfg_to"
                       value="{{ index .Config "to" }}" placeholder="123456789" />
            </div>
            <div class="form-group">
                <label>Message Type <span class="text-muted">(optional)</span></label>
                <select class="form-control" name="cfg_type" style="width:auto;">
                    <option value=""        {{ if eq (index .Config "type") ""        }}selected{{ end }}>— auto —</option>
                    <option value="private" {{ if eq (index .Config "type") "private" }}selected{{ end }}>private</option>
                    <option value="group"   {{ if eq (index .Config "type") "group"   }}selected{{ end }}>group</option>
                </select>
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Evolution API (WhatsApp) -->
        <!-- ======================================================= -->
        <div id="fields-evolution" class="provider-fields">
            <div class="form-group">
                <label>Evolution API URL</label>
                <input class="form-control" type="url" name="cfg_url"
                       value="{{ index .Config "url" }}" placeholder="http://evolution:8080" />
            </div>
            <div class="form-group">
                <label>API Key</label>
                <input class="form-control" type="password" name="cfg_api_key"
                       value="{{ index .Config "api_key" }}" autocomplete="new-password" />
            </div>
            <div class="form-group">
                <label>Instance Name</label>
                <input class="form-control" type="text" name="cfg_instance"
                       value="{{ index .Config "instance" }}" placeholder="my-whatsapp" />
            </div>
            <div class="form-group">
                <label>Recipient Phone Number</label>
                <input class="form-control" type="tel" name="cfg_phone"
                       value="{{ index .Config "phone" }}" placeholder="+12025551234" />
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Email (SMTP) -->
        <!-- ======================================================= -->
        <div id="fields-email" class="provider-fields">
            <div class="two-col">
                <div class="form-group">
                    <label>SMTP Host</label>
                    <input class="form-control" type="text" name="cfg_host"
                           value="{{ index .Config "host" }}" placeholder="smtp.gmail.com" />
                </div>
                <div class="form-group">
                    <label>Port</label>
                    <input class="form-control" type="number" name="cfg_port"
                           value="{{ index .Config "port" }}" placeholder="465" style="width:100%;" />
                </div>
            </div>
            <div class="two-col">
                <div class="form-group">
                    <label>Username</label>
                    <input class="form-control" type="text" name="cfg_username"
                           value="{{ index .Config "username" }}" />
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input class="form-control" type="password" name="cfg_password"
                           value="{{ index .Config "password" }}" autocomplete="new-password" />
                </div>
            </div>
            <div class="two-col">
                <div class="form-group">
                    <label>From Address</label>
                    <input class="form-control" type="email" name="cfg_from"
                           value="{{ index .Config "from" }}" placeholder="monitor@example.com" />
                </div>
                <div class="form-group">
                    <label>To Address(es) <span class="text-muted">(comma-separated)</span></label>
                    <input class="form-control" type="text" name="cfg_to"
                           value="{{ index .Config "to" }}" placeholder="admin@example.com" />
                </div>
            </div>
            <div class="form-group">
                <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
                    <input type="checkbox" name="cfg_tls" value="true"
                           {{ if ne (index .Config "tls") "false" }}checked{{ end }} />
                    Use TLS (port 465) — uncheck for STARTTLS (port 587)
                </label>
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Email API: SendGrid / Resend / seven.io               -->
        <!-- (all share: api_key, from, to)                          -->
        <!-- ======================================================= -->
        <div id="fields-email-api" class="provider-fields">
            <div class="form-group">
                <label>API Key</label>
                <input class="form-control" type="password" name="cfg_api_key"
                       value="{{ index .Config "api_key" }}" autocomplete="new-password" />
            </div>
            <div class="two-col">
                <div class="form-group">
                    <label>From</label>
                    <input class="form-control" type="text" name="cfg_from"
                           value="{{ index .Config "from" }}" placeholder="monitor@example.com or +15551234567" />
                </div>
                <div class="form-group">
                    <label>To</label>
                    <input class="form-control" type="text" name="cfg_to"
                           value="{{ index .Config "to" }}" placeholder="alerts@example.com or +15559876543" />
                </div>
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- Twilio -->
        <!-- ======================================================= -->
        <div id="fields-twilio" class="provider-fields">
            <div class="two-col">
                <div class="form-group">
                    <label>Account SID</label>
                    <input class="form-control" type="text" name="cfg_account_sid"
                           value="{{ index .Config "account_sid" }}" placeholder="ACxxxxxxxxxxxxxx" />
                </div>
                <div class="form-group">
                    <label>Auth Token</label>
                    <input class="form-control" type="password" name="cfg_auth_token"
                           value="{{ index .Config "auth_token" }}" autocomplete="new-password" />
                </div>
            </div>
            <div class="two-col">
                <div class="form-group">
                    <label>From Number</label>
                    <input class="form-control" type="tel" name="cfg_from"
                           value="{{ index .Config "from" }}" placeholder="+15551234567" />
                </div>
                <div class="form-group">
                    <label>To Number</label>
                    <input class="form-control" type="tel" name="cfg_to"
                           value="{{ index .Config "to" }}" placeholder="+15559876543" />
                </div>
            </div>
        </div>

        <!-- ======================================================= -->
        <!-- SMS credentials group: username/password/from/to        -->
        <!-- Used by: 46elks, Cellsynt, GTX Messaging, SerwerSMS     -->
